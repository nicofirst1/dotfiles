# This script defines various aliases for convenient command line usage.

# Alias to activate a virtual environment
alias src="source activate"

# Check if lsd is installed and set aliases accordingly
if command -v lsd &> /dev/null; then
    alias ls="lsd"
    alias la='lsd -A'
    alias lsa='lsd -lA'
else
    alias la='ls -lA'
fi

# Check if bat is installed and set aliases accordingly
if command -v bat &> /dev/null; then
    alias cat="bat"

    # Function to tail -f a file with bat
    tf() {
        tail -f $1 | bat --paging=never -l log
    }
    
    # Function to show git diff with bat
    batdiff() {
        git diff --name-only --relative --diff-filter=d | xargs bat --diff
    }
fi

# Path aliases
cd() {
    if [[ $1 == "..." ]]; then
        builtin cd ../../
    elif [[ $1 == "...." ]]; then
        builtin cd ../../../
    elif [[ $1 == "....." ]]; then
        builtin cd ../../../../
    else
        builtin cd "$@"
    fi
}

# Midnight Commander aliased to `data-clean` (minio's `mc` owns the default name).
# On macOS the homebrew keg-only install lives under /opt/homebrew; on Linux the
# distro package puts mc on PATH directly, so no aliasing is needed there.
if [[ -x /opt/homebrew/opt/midnight-commander/bin/mc ]]; then
    alias data-clean="/opt/homebrew/opt/midnight-commander/bin/mc"
elif command -v mc &> /dev/null; then
    alias data-clean="mc"
fi

# check if tmux is installed
if command -v tmux &> /dev/null; then
    alias tat="tmux attach -t"
fi

# check if fzf-tmux is installed
if command -v fzf-tmux &> /dev/null; then
    alias fzf="fzf-tmux"
fi

alias gcm="git commit -m"

alias afa="autoflake --in-place --remove-unused-variables --remove-all-unused-imports  --recursive"

# WireGuard tunnel (FritzBox home, split-tunnel — only 192.168.178.0/24)
if command -v wg-quick &> /dev/null; then
    _WG_CONF="$HOME/Documents/wg_config.conf"
    alias wgup="sudo wg-quick up $_WG_CONF"
    alias wgdown="sudo wg-quick down $_WG_CONF"
    alias wgstatus="sudo wg show"
fi